    "name": "TodoList API",
    "description": "Collection para testar a API de tarefas em Spring Boot.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tarefas",
      "item": [
        {
          "name": "Listar todas as tarefas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tarefas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta é um array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar tarefa por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tarefas/{{tarefaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas",
                "{{tarefaId}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna o id solicitado', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(Number(pm.collectionVariables.get('tarefaId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Criar tarefa",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Estudar Spring Boot\",\n  \"descricao\": \"Revisar controller, service e repository\",\n  \"prazo\": \"2026-07-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tarefas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Cria tarefa com id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.collectionVariables.set('tarefaId', json.id);",
                  "});",
                  "pm.test('Status inicial pendente', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('PENDENTE');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Atualizar tarefa completa",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Estudar Spring Boot com testes\",\n  \"descricao\": \"Revisar service, controller e cobertura\",\n  \"prazo\": \"2026-07-12\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tarefas/{{tarefaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas",
                "{{tarefaId}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Atualiza o título', function () {",
                  "    pm.expect(pm.response.json().titulo).to.eql('Estudar Spring Boot com testes');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Atualizar status da tarefa",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONCLUIDA\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tarefas/{{tarefaId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas",
                "{{tarefaId}}",
                "status"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Atualiza o status para concluída', function () {",
                  "    pm.expect(pm.response.json().status).to.eql('CONCLUIDA');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Excluir tarefa",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tarefas/{{tarefaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tarefas",
                "{{tarefaId}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
